# Provider selection: ollama (default, local) | anthropic | openai | gemini | groq
LLM_PROVIDER=ollama

# Ollama (local, free). Pull a model with: ollama pull llama3.1:8b
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# Anthropic (optional)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# OpenAI (optional)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Gemini (optional bonus provider)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# Groq (optional bonus provider)
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# Retrieval gating
CONFIDENCE_THRESHOLD=0.72

# Embedding model (sentence-transformers, downloaded on first use)
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
